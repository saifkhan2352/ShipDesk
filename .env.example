# ── CLERK ──────────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=                     # Server-side key for JWT verification (sk_live_...)
CLERK_WEBHOOK_SECRET=                 # svix signing secret from Clerk dashboard (whsec_...)
VITE_CLERK_PUBLISHABLE_KEY=           # Frontend publishable key (pk_live_...)

# ── DATABASE ───────────────────────────────────────────────────────────────────
DATABASE_URL=                         # PostgreSQL connection string

# ── GITHUB ─────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=                     # OAuth App client ID
GITHUB_CLIENT_SECRET=                 # OAuth App client secret
GITHUB_WEBHOOK_SECRET=                # HMAC-SHA256 signing secret
GITHUB_OAUTH_CALLBACK_URL=            # Full OAuth callback URL

# ── GOOGLE GEMINI ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=                       # Google AI Studio API key for gemini-1.5-pro

# ── CLOUDINARY ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# ── LEMON SQUEEZY ──────────────────────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_PRODUCT_ID=
LEMONSQUEEZY_VARIANT_ID=

# ── EMAIL (RESEND) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ── SECURITY ───────────────────────────────────────────────────────────────────
SESSION_SECRET=                       # ≥ 32-char random string
AES_ENCRYPTION_KEY=                   # Exactly 64 hex chars (32 bytes = 256 bits)

# ── APP URLS ───────────────────────────────────────────────────────────────────
FRONTEND_URL=
BACKEND_URL=
CLIENT_PORTAL_BASE_URL=
VITE_API_BASE_URL=

# ── SERVER ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
